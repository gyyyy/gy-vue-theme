{
  "name": "gy-vue-theme",
  "version": "1.0.0",
  "description": "A design-token based Vue theme library with three-layer token architecture",
  "type": "module",
  "main": "./dist/lib/index.cjs",
  "module": "./dist/es/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/es/index.mjs",
      "require": "./dist/lib/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc --emitDeclarationOnly",
    "prepare": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "dependencies": {
    "@ctrl/tinycolor": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^27.0.1",
    "less": "^4.5.1",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "vue3",
    "vue",
    "theme",
    "design-token",
    "design-system",
    "css-variables",
    "dark-mode",
    "theming"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gyyyy/gy-vue-theme"
  },
  "workspaces": [
    "packages/*"
  ]
}
